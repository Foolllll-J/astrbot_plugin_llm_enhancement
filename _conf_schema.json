{
    "group_whitelist": {
        "description": "群聊白名单",
        "hint": "仅在群聊白名单里的群启用本插件功能，不填表示所有群聊都启用。",
        "type": "list",
        "default": []
    },
    "intelligent_wake": {
        "type": "object",
        "description": "智能唤醒",
        "hint": "配置智能唤醒相关参数",
        "items": {
            "max_user_concurrent_requests": {
                "description": "用户级并发请求上限",
                "hint": "限制单个用户同时进行中的 LLM 请求数。设为 0 表示不限制。",
                "type": "int",
                "minimum": 0,
                "default": 0
            },
            "max_group_concurrent_requests": {
                "description": "群聊级并发请求上限",
                "hint": "限制单个群同时进行中的 LLM 请求数。设为 0 表示不限制。",
                "type": "int",
                "minimum": 0,
                "default": 0
            },
            "wake_extend": {
                "description": "唤醒延长(秒)",
                "hint": "LLM 响应后，在此时间窗口内可继续维持唤醒状态。设为 0 时关闭。",
                "type": "float",
                "default": 30.0
            },
            "wake_extend_same_user_only": {
                "description": "唤醒延长仅对原用户生效",
                "hint": "开启后，唤醒延长窗口内仅处理上次触发请求的用户消息，忽略其他用户。",
                "type": "bool",
                "default": true
            },
            "wake_extend_similarity": {
                "description": "唤醒延长相关性阈值",
                "hint": "唤醒延长期间，当前消息与上文的相关性阈值。",
                "type": "float",
                "default": 0.1
            },
            "wake_extend_provider_id": {
                "description": "唤醒延长判定 Provider ID",
                "type": "string",
                "_special": "select_provider",
                "default": "",
                "hint": "留空时不启用模型判定。配置后会让该模型仅输出 T/F，用于判断是否继续响应。"
            },
            "wake_extend_judge_prompt": {
                "description": "唤醒延长判定提示词",
                "type": "text",
                "obvious_hint": true,
                "editor_mode": true,
                "editor_language": "markdown",
                "editor_theme": "vs-dark",
                "default": "请判断当前消息是否与上文足够相关，是否需要继续响应。\n\n[当前时间]\n{time}\n\n[用户ID]\n{user_id}\n\n[用户名]\n{user_name}\n\n[群组ID]\n{group_id}\n\n[相关性阈值参考]\n{threshold}\n\n[上文]\n{history}\n\n[当前消息]\n{message}\n\n[判定规则]\n1) 如果当前消息是对上文的自然追问、补充、纠正、承接或继续讨论，输出 T。\n2) 如果当前消息与上文明显无关、话题跳转过大，或不需要机器人继续响应，输出 F。\n3) 不确定时优先结合上文连续性判断；只有在明显无关时才输出 F。\n\n[输出格式]\n只能输出一个大写字母：T 或 F。",
                "hint": "支持占位符：{time}、{user_id}、{user_name}、{group_id}、{threshold}、{history}、{message}、{persona}、{random}。仅在配置了 wake_extend_provider_id 时生效。"
            },
            "wake_judge_provider_id": {
                "description": "唤醒判定 Provider ID",
                "type": "string",
                "_special": "select_provider",
                "default": "",
                "hint": "仅用于普通 @ / 唤醒前缀请求的唤醒判定。留空表示不启用该判定。"
            },
            "wake_judge_prompt": {
                "description": "唤醒判定提示词",
                "type": "text",
                "obvious_hint": true,
                "editor_mode": true,
                "editor_language": "markdown",
                "editor_theme": "vs-dark",
                "default": "你是群聊“唤醒判定器”。请判断机器人是否应该响应这条显式唤醒请求。\n\n[当前时间]\n{time}\n\n[用户ID]\n{user_id}\n\n[用户名]\n{user_name}\n\n[群组ID]\n{group_id}\n\n[最近上下文]\n{history}\n\n[当前消息]\n{message}\n\n[判定规则]\n1) 用户明确表示“别回复/不用回/闭嘴/停下”等，输出 F。\n2) 当前消息仅为收尾确认（如“嗯/好/知道了/收到/晚安/拜拜/谢谢”）且没有新问题或新任务，输出 F。\n3) 含有新的问题、任务、追问，或明确要求继续，输出 T。\n4) 不确定时优先输出 T，避免漏回关键请求。\n\n[输出格式]\n只能输出一个大写字母：T 或 F。",
                "hint": "支持占位符：{time}、{user_id}、{user_name}、{group_id}、{history}、{message}、{persona}、{random}。"
            },
            "wake_judge_context_count": {
                "description": "唤醒判定上下文条数",
                "hint": "唤醒判定与唤醒延长共用的上下文条数。默认 10，且不会超过“上下文记录上限”。",
                "type": "int",
                "default": 10,
                "minimum": 1
            },
            "active_wake_judge_types": {
                "description": "主动唤醒判定类型",
                "hint": "选择后，这些主动唤醒类型会在触发后再经过一次唤醒判定。留空表示不对主动唤醒额外判定。",
                "type": "list",
                "options": [
                    "mention",
                    "relevant",
                    "ask",
                    "bored",
                    "prob"
                ],
                "labels": [
                    "提及唤醒",
                    "相关性唤醒",
                    "答疑唤醒",
                    "无聊唤醒",
                    "兜底概率唤醒"
                ],
                "default": []
            },
            "mention_wake": {
                "description": "提及唤醒规则",
                "hint": "支持普通文本包含、re:pattern 与 /pattern/flags（flags: i,m,s,x,a,u,L）。不填时关闭提及检测。",
                "type": "list",
                "default": []
            },
            "relevant_wake": {
                "description": "相关性唤醒阈值",
                "hint": "当前消息与上文bot的消息相关性超过阈值时，唤醒bot。设为 0 时关闭检测。",
                "type": "float",
                "default": 0.68
            },
            "ask_wake": {
                "description": "答疑唤醒阈值",
                "hint": "当群里有人问专业性问题时，唤醒bot。设为 0 时关闭检测。",
                "type": "float",
                "default": 0.78
            },
            "bored_wake": {
                "description": "无聊唤醒阈值",
                "hint": "当群里出现无聊/冷场/求聊天等表达时，唤醒bot。设为 0 时关闭检测。",
                "type": "float",
                "default": 0.74
            },
            "shutup": {
                "description": "闭嘴检测阈值",
                "hint": "有人感觉bot太多话时，bot自动闭嘴一段时间。设为 0 时关闭检测。",
                "type": "float",
                "default": 0.72
            },
            "insult": {
                "description": "辱骂检测阈值",
                "hint": "有人辱骂bot时，bot自动沉默一段时间。设为 0 时关闭检测。",
                "type": "float",
                "default": 0.75
            },
            "silence_multiple": {
                "description": "沉默时间倍数",
                "hint": "触发bot沉默时的阈值（0~1） * 沉默时间倍数 = 沉默时间。",
                "type": "float",
                "default": 300
            },
            "prob_wake": {
                "description": "兜底唤醒概率",
                "hint": "上述所有唤醒机制都没能唤醒bot时，最后会按照此概率尝试唤醒bot。",
                "type": "float",
                "default": 0.0002
            },
            "require_at_for_wake_prefix": {
                "description": "唤醒需 @Bot",
                "hint": "开启后，仅通过唤醒前缀触发的 LLM 请求会被拦截，必须 @Bot 或引用 Bot 消息才放行。",
                "type": "bool",
                "default": false
            },
            "wake_forbidden_words": {
                "description": "屏蔽唤醒规则",
                "hint": "支持格式同唤醒规则。命中规则时不会唤醒bot。",
                "type": "list",
                "default": [
                    "政治",
                    "键证",
                    "党"
                ]
            },
            "block_builtin": {
                "description": "屏蔽内置指令",
                "hint": "内置指令即指 Astrbot 自带的命令，如 help, tts, llm 等，内置指令被屏蔽后不再会唤醒bot。",
                "type": "bool",
                "default": false
            }
        }
    },
    "merge": {
        "type": "object",
        "description": "消息合并",
        "hint": "配置硬等待合并与动态合并的行为。",
        "items": {
            "merge_dynamic_mode": {
                "description": "合并模式",
                "hint": "硬合并：按合并延迟做等待收集；动态合并：检测到新消息时丢弃上一轮响应并在下一轮合并重算。",
                "type": "string",
                "options": [
                    "hard",
                    "dynamic"
                ],
                "labels": [
                    "硬合并",
                    "动态合并"
                ],
                "default": "hard"
            },
            "merge_delay": {
                "description": "合并窗口(秒)",
                "hint": "硬合并下表示硬等待时间；动态合并下表示可并入消息的时间窗口上限。设为 0 时不启用消息合并。",
                "type": "float",
                "default": 0
            },
            "merge_max_count": {
                "description": "合并数量上限",
                "hint": "单次最多可合并的消息条数，超过上限后将停止继续收集。",
                "type": "int",
                "default": 3
            },
            "merge_followup_require_wake": {
                "description": "后续合并需再次唤醒",
                "hint": "开启后，仅并入满足唤醒条件的后续消息；关闭时并入窗口内任意后续消息。",
                "type": "bool",
                "default": false
            },
            "merge_multi_user": {
                "description": "允许合并多人消息",
                "hint": "开启后，合并窗口期间若有其他群成员发送消息，也会被一并收集。",
                "type": "bool",
                "default": false
            }
        }
    },
    "context_injection": {
        "type": "object",
        "description": "上下文注入",
        "hint": "用于记录并注入轻量对话上下文，为后续读空气与主动唤醒优化提供基础数据。",
        "items": {
            "context_injection_mode": {
                "description": "上下文注入模式",
                "hint": "控制轻量上下文记录与注入策略。",
                "type": "string",
                "options": [
                    "off",
                    "before_active_only",
                    "before_all_wake"
                ],
                "labels": [
                    "不启用",
                    "仅主动唤醒前",
                    "所有唤醒前"
                ],
                "default": "off"
            },
            "context_injection_max_messages": {
                "description": "上下文记录上限",
                "hint": "每个会话最多保留的上下文消息条数（环形缓存）。建议 6~50。",
                "type": "int",
                "default": 12
            },
            "context_injection_format": {
                "description": "上下文注入格式",
                "hint": "精简：仅注入时间+发送者+文本（含引用摘要）；详细：注入完整结构字段（含 msg_id、uid、@信息、reply 信息）。",
                "type": "string",
                "options": [
                    "simple",
                    "detailed"
                ],
                "labels": [
                    "精简",
                    "详细"
                ],
                "default": "simple"
            },
            "context_injection_non_text_parse_options": {
                "description": "非文本消息解析选项",
                "hint": "控制上下文记录阶段对非文本消息的处理方式。未勾选时使用占位符。聊天记录仅抽取文本，不做媒体解析。",
                "type": "list",
                "options": [
                    "image",
                    "forward",
                    "url",
                    "file",
                    "json"
                ],
                "labels": [
                    "图片",
                    "聊天记录",
                    "URL",
                    "文件",
                    "JSON"
                ],
                "default": []
            },
            "context_injection_image_caption_provider_id": {
                "description": "上下文图像转述 Provider ID",
                "type": "string",
                "_special": "select_provider",
                "default": "",
                "hint": "留空时自动选择具备图片能力的 Provider。"
            }
        }
    },
    "parse_switches": {
        "type": "object",
        "description": "解析总开关",
        "hint": "统一控制各类内容解析能力是否启用。",
        "items": {
            "video_parse_enable": {
                "description": "启用视频解析",
                "type": "bool",
                "default": true,
                "hint": "关闭后，不再执行视频与 GIF 的媒体增强解析。"
            },
            "forward_parse_enable": {
                "description": "启用聊天记录解析",
                "type": "bool",
                "default": true,
                "hint": "关闭后，不再解析聊天记录（转发消息）内容。"
            },
            "file_parse_enable": {
                "description": "启用文件解析",
                "type": "bool",
                "default": true,
                "hint": "关闭后，不再提取或注入引用消息中的文件信息。"
            },
            "json_parse_enable": {
                "description": "启用 JSON 卡片解析",
                "type": "bool",
                "default": true,
                "hint": "关闭后，不再提取引用消息中的 JSON 卡片关键信息（如分享卡片标题、摘要、链接）。"
            },
            "url_parse_enable": {
                "description": "启用 URL 解析",
                "type": "bool",
                "default": true,
                "hint": "关闭后，不再抓取并注入消息中的 URL 内容摘要。"
            }
        }
    },
    "video_injection": {
        "type": "object",
        "description": "视频解析",
        "hint": "配置视频抽帧、语音识别和相关模型参数。",
        "items": {
            "video_max_size_mb": {
                "description": "视频大小上限（MB）",
                "hint": "单个视频超过该大小时将跳过解析。默认 50MB。",
                "type": "int",
                "default": 50
            },
            "gif_parse_enable": {
                "description": "启用 GIF 抽帧解析",
                "type": "bool",
                "default": false,
                "hint": "关闭时，GIF 不走插件抽帧流程，保留框架原生图片处理；开启后，GIF 将按类似视频的方式抽帧总结。"
            },
            "video_frame_interval_sec": {
                "description": "抽帧间隔（秒）",
                "hint": "每隔 N 秒取 1 帧。间隔越小描述越细腻，但会消耗更多 Token 和时间。",
                "type": "int",
                "default": 12
            },
            "video_max_frame_count": {
                "description": "抽帧数量上限",
                "type": "int",
                "default": 10,
                "hint": "单个视频最多抽取的帧数。若根据抽帧间隔计算出的帧数超过此值，将自动调整间隔以匹配此上限。"
            },
            "video_sample_count": {
                "description": "视频抽帧数量",
                "type": "int",
                "default": 3,
                "hint": "当无法探测视频时长时，默认抽取该数量的帧。"
            },
            "video_asr_enable": {
                "description": "视频语音识别 (ASR)",
                "type": "bool",
                "default": true,
                "hint": "开启后，将提取视频音频并转写为文本，辅助模型理解视频内容。"
            },
            "asr_provider_id": {
                "description": "ASR 提供商 ID",
                "type": "string",
                "_special": "select_provider_stt",
                "hint": "留空时使用当前会话的 STT 提供商。"
            },
            "image_provider_id": {
                "description": "图片转述 Provider ID",
                "type": "string",
                "_special": "select_provider",
                "hint": "留空时自动选择具备图片能力的 Provider。"
            },
            "ffmpeg_path": {
                "description": "FFmpeg 路径",
                "hint": "FFmpeg 可执行文件路径，不填则自动尝试从系统环境变量中寻找。",
                "type": "string",
                "default": ""
            },
            "quote_self_video_block_prob": {
                "description": "引用 Bot 自身视频的请求屏蔽概率",
                "hint": "当引用 Bot 自身发送的视频消息时，按该概率屏蔽请求。",
                "type": "float",
                "slider": {
                    "min": 0,
                    "max": 1,
                    "step": 0.01
                },
                "default": 0
            }
        }
    },
    "forward_parsing": {
        "type": "object",
        "description": "聊天记录解析",
        "hint": "配置聊天记录解析的策略与限制。",
        "items": {
            "nested_parse_depth": {
                "description": "嵌套解析深度",
                "type": "int",
                "default": 5,
                "hint": "限制递归解析层数。"
            },
            "forward_message_max_count": {
                "description": "消息读取上限",
                "type": "int",
                "default": 50,
                "hint": "单次最多读取并解析的聊天记录内部消息条数。"
            },
            "forward_image_max_count": {
                "description": "图片注入上限",
                "type": "int",
                "default": 8,
                "hint": "单次聊天记录解析最多注入的图片数量，超出部分将被忽略。"
            },
            "forward_video_max_count": {
                "description": "最多处理视频数量",
                "type": "int",
                "default": 2,
                "hint": "单次聊天记录解析最多处理的视频条数。设为 0 时关闭聊天记录视频抽帧，仅保留视频占位符。"
            },
            "forward_video_max_frame_count": {
                "description": "聊天记录视频最多抽帧数量",
                "type": "int",
                "default": 1,
                "hint": "单个聊天记录视频最多抽取的帧数。设为 0 时关闭聊天记录视频抽帧，仅保留视频占位符。"
            },
            "quote_self_forward_block_prob": {
                "description": "引用 Bot 自身聊天记录的请求屏蔽概率",
                "hint": "当引用 Bot 自身发送的聊天记录消息时，按该概率屏蔽请求。",
                "type": "float",
                "slider": {
                    "min": 0,
                    "max": 1,
                    "step": 0.01
                },
                "default": 0
            }
        }
    },
    "file_parsing": {
        "type": "object",
        "description": "文件解析",
        "hint": "配置引用消息中的文件解析行为。",
        "items": {
            "inject_file_name": {
                "description": "注入文件名",
                "type": "bool",
                "default": true,
                "hint": "开启后，引用消息中的文件名会注入到上下文。"
            },
            "inject_file_max_size_mb": {
                "description": "文件内容解析大小上限（MB）",
                "type": "int",
                "default": 20,
                "minimum": 0,
                "hint": "超过该大小的文件不会解析内容并注入；设为 0 表示不限制。"
            },
            "inject_file_text_length": {
                "description": "文件文本注入长度",
                "type": "int",
                "default": 0,
                "minimum": 0,
                "hint": "大于 0 时会读取可直接解析的文件并注入前 N 个字符；设为 0 表示关闭。"
            },
            "quote_self_file_block_prob": {
                "description": "引用 Bot 自身文件的请求屏蔽概率",
                "hint": "当引用 Bot 自身发送的文件消息时，按该概率屏蔽请求。",
                "type": "float",
                "slider": {
                    "min": 0,
                    "max": 1,
                    "step": 0.01
                },
                "default": 0
            }
        }
    },
    "url_parsing": {
        "type": "object",
        "description": "URL 解析注入",
        "hint": "配置 URL 抓取与安全策略。",
        "items": {
            "inject_url_timeout_sec": {
                "description": "URL 抓取超时（秒）",
                "type": "int",
                "default": 8,
                "minimum": 2,
                "hint": "单个链接抓取的超时时间。"
            },
            "inject_url_max_download_kb": {
                "description": "URL 下载大小上限（KB）",
                "type": "int",
                "default": 512,
                "minimum": 32,
                "hint": "单个链接最多下载的内容大小，超出将停止正文解析。"
            },
            "inject_url_block_private_network": {
                "description": "拦截内网 URL",
                "type": "bool",
                "default": true,
                "hint": "开启后，非 bot 管理员不允许解析内网地址。"
            },
