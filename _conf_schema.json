{
    "group_whitelist": {
        "description": "群聊白名单",
        "hint": "仅在群聊白名单里的群启用本插件功能，不填表示所有群聊都启用。",
        "type": "list",
        "default": []
    },
    "intelligent_wake": {
        "type": "object",
        "description": "智能唤醒",
        "hint": "配置智能唤醒相关参数。",
        "items": {
            "prob_wake": {
                "description": "概率唤醒活跃度",
                "hint": "数值越高，Bot 在普通群消息中的主动插话意愿越强。设为 0 时关闭该模式。",
                "type": "float",
                "default": 0.3,
                "slider": {
                    "min": 0,
                    "max": 1,
                    "step": 0.1
                },
                "minimum": 0,
                "maximum": 1
            },
            "mention_wake": {
                "description": "提及唤醒规则",
                "hint": "支持普通文本包含与 re:pattern（正则）。不填时关闭提及检测。",
                "type": "list",
                "default": []
            },
            "relevant_wake": {
                "description": "相关性唤醒阈值",
                "hint": "当前消息与上文 Bot 的消息相关性超过阈值时，唤醒 Bot。设为 0 时关闭检测。",
                "type": "float",
                "default": 0.68,
                "slider": {
                    "min": 0,
                    "max": 1,
                    "step": 0.01
                },
                "minimum": 0,
                "maximum": 1
            },
            "ask_wake": {
                "description": "答疑唤醒阈值",
                "hint": "当群里有人问专业性问题时，唤醒 Bot。设为 0 时关闭检测。",
                "type": "float",
                "default": 0.78,
                "slider": {
                    "min": 0,
                    "max": 1,
                    "step": 0.01
                },
                "minimum": 0,
                "maximum": 1
            },
            "bored_wake": {
                "description": "无聊唤醒阈值",
                "hint": "当群里出现无聊/冷场/求聊天等表达时，唤醒 Bot。设为 0 时关闭检测。",
                "type": "float",
                "default": 0.74,
                "slider": {
                    "min": 0,
                    "max": 1,
                    "step": 0.01
                },
                "minimum": 0,
                "maximum": 1
            },
            "active_wake_silence_bonus_enabled": {
                "description": "主动唤醒沉默补偿",
                "hint": "开启后，Bot 距离上次回复后累积的消息越多，会更容易触发语义型主动唤醒。",
                "type": "bool",
                "default": true
            },
            "wake_judge_types": {
                "description": "唤醒判定类型",
                "hint": "选择后，这些唤醒类型会在触发后再经过一次唤醒判定。留空表示不额外判定。",
                "type": "list",
                "options": [
                    "explicit",
                    "prob",
                    "mention",
                    "relevant",
                    "ask",
                    "bored"
                ],
                "labels": [
                    "显式唤醒",
                    "概率唤醒",
                    "提及唤醒",
                    "相关性唤醒",
                    "答疑唤醒",
                    "无聊唤醒"
                ],
                "default": [
                    "prob"
                ]
            },
            "wake_judge_provider_id": {
                "description": "唤醒判定 Provider ID",
                "type": "string",
                "_special": "select_provider",
                "default": "",
                "hint": "用于选中的各类唤醒类型的后置判定。留空表示不启用该判定。"
            },
            "wake_judge_prompt": {
                "description": "唤醒判定提示词",
                "type": "text",
                "obvious_hint": true,
                "editor_mode": true,
                "editor_language": "markdown",
                "editor_theme": "vs-dark",
                "default": "你是群聊“唤醒判定器”。请判断机器人是否应该响应这条显式唤醒请求。\n\n[当前时间]\n{time}\n\n[用户ID]\n{user_id}\n\n[用户名]\n{user_name}\n\n[群组ID]\n{group_id}\n\n[最近上下文]\n{history}\n\n[当前消息]\n{message}\n\n[判定规则]\n1) 用户明确表示“别回复/不用回/闭嘴/停下”等，输出 F。\n2) 当前消息仅为收尾确认（如“嗯/好/知道了/收到/晚安/拜拜/谢谢”）且没有新问题或新任务，输出 F。\n3) 含有新的问题、任务、追问，或明确要求继续，输出 T。\n4) 不确定时优先输出 T，避免漏回关键请求。\n\n[输出格式]\n只能输出一个大写字母：T 或 F。",
                "hint": "支持占位符：{time}、{user_id}、{user_name}、{group_id}、{history}、{message}、{persona}、{rN}、{schedule}（需安装 life_scheduler 插件）。"
            },
            "wake_extend": {
                "description": "唤醒延长（秒）",
                "hint": "LLM 响应后，在此时间窗口内可继续维持唤醒状态。设为 0 时关闭。",
                "type": "float",
                "default": 30.0
            },
            "wake_extend_same_user_only": {
                "description": "唤醒延长仅对原用户生效",
                "hint": "开启后，唤醒延长窗口内仅处理上次触发请求的用户消息，忽略其他用户。",
                "type": "bool",
                "default": true
            },
            "wake_extend_similarity": {
                "description": "唤醒延长相关性阈值",
                "hint": "唤醒延长期间，当前消息与上文的相关性阈值。",
                "type": "float",
                "default": 0.12,
                "slider": {
                    "min": 0,
                    "max": 1,
                    "step": 0.01
                },
                "minimum": 0,
                "maximum": 1
            },
            "wake_extend_provider_id": {
                "description": "唤醒延长判定 Provider ID",
                "type": "string",
                "_special": "select_provider",
                "default": "",
                "hint": "留空时不启用模型判定。配置后会让该模型仅输出 T/F，用于判断是否继续响应。"
            },
            "wake_extend_judge_prompt": {
                "description": "唤醒延长判定提示词",
                "type": "text",
                "obvious_hint": true,
                "editor_mode": true,
                "editor_language": "markdown",
                "editor_theme": "vs-dark",
                "default": "请判断当前消息是否与上文足够相关，是否需要继续响应。\n\n[当前时间]\n{time}\n\n[用户ID]\n{user_id}\n\n[用户名]\n{user_name}\n\n[群组ID]\n{group_id}\n\n[相关性阈值参考]\n{threshold}\n\n[上文]\n{history}\n\n[当前消息]\n{message}\n\n[判定规则]\n1) 如果当前消息是对上文的自然追问、补充、纠正、承接或继续讨论，输出 T。\n2) 如果当前消息与上文明显无关、话题跳转过大，或不需要机器人继续响应，输出 F。\n3) 不确定时优先结合上文连续性判断；只有在明显无关时才输出 F。\n\n[输出格式]\n只能输出一个大写字母：T 或 F。",
                "hint": "支持占位符：{time}、{user_id}、{user_name}、{group_id}、{threshold}、{history}、{message}、{persona}、{rN}、{schedule}。仅在配置了 唤醒延长判定 Provider ID 时生效。"
            },
            "wake_judge_context_count": {
                "description": "唤醒判定上下文条数",
                "hint": "唤醒判定与唤醒延长共用的上下文条数。默认 10，且不会超过“上下文记录上限”。",
                "type": "int",
                "default": 10,
                "minimum": 1
            },
            "wake_llm_timeout_sec": {
                "description": "唤醒判定模型超时（秒）",
                "hint": "用于“唤醒判定”和“唤醒延长”的模型判定等待时间。超时后唤醒判定直接放行，唤醒延长回退到本地相似度判定。设为 0 表示不启用超时。",
                "type": "int",
                "default": 5,
                "minimum": 0,
                "maximum": 30,
                "slider": {
                    "min": 0,
                    "max": 30,
                    "step": 1
                }
            },
            "wake_forbidden_words": {
                "description": "屏蔽唤醒规则",
                "hint": "支持格式同唤醒规则。命中规则时不会唤醒 Bot。",
                "type": "list",
                "default": [
                    "政治",
                    "键证",
                    "党"
                ]
            },
            "require_at_for_wake_prefix": {
                "description": "唤醒需 @Bot",
                "hint": "开启后，仅通过唤醒前缀触发的 LLM 请求会被拦截，必须 @Bot 或引用 Bot 消息才放行。",
                "type": "bool",
                "default": false
            },
            "bot_account_ids": {
                "description": "机器人 ID",
                "hint": "配置其他机器人的用户 ID。",
                "type": "list",
                "default": []
            },
            "bot_account_skip_wake_types": {
                "description": "机器人消息跳过类型",
                "hint": "来自其他机器人的消息将跳过所选唤醒逻辑。",
                "type": "list",
                "options": [
                    "explicit",
                    "active",
                    "wake_extend"
                ],
                "labels": [
                    "显式唤醒",
                    "主动唤醒",
                    "唤醒延长"
                ],
                "default": []
            }
        }
    },
    "request_orchestration": {
        "type": "object",
        "description": "请求编排",
        "hint": "控制 LLM 请求的合并策略、并发上限和群聊按用户并发。",
        "items": {
            "merge_dynamic_mode": {
                "description": "合并模式",
                "hint": "硬合并：按合并延迟做等待收集；动态合并：检测到新消息时丢弃上一轮响应并在下一轮合并重算。",
                "type": "string",
                "options": [
                    "hard",
                    "dynamic"
                ],
                "labels": [
                    "硬合并",
                    "动态合并"
                ],
                "default": "dynamic"
            },
            "merge_delay": {
                "description": "合并窗口（秒）",
                "hint": "硬合并下表示硬等待时间；动态合并下表示可并入消息的时间窗口上限。设为 0 时不启用消息合并。",
                "type": "float",
                "default": 0
            },
            "merge_max_count": {
                "description": "合并数量上限",
                "hint": "单次最多可合并的消息条数，超过上限后将停止继续收集。",
                "type": "int",
                "default": 2
            },
            "merge_premerge_window": {
                "description": "预合并窗口（秒）",
                "hint": "唤醒前，将在此窗口秒数内的用户消息作为预合并候选。仅动态合并模式生效，设为 0 时关闭预合并。",
                "type": "int",
                "default": 0
            },
            "merge_followup_require_wake": {
                "description": "后续合并需再次唤醒",
                "hint": "开启后，仅并入满足唤醒条件的后续消息；关闭时并入窗口内任意后续消息。",
                "type": "bool",
                "default": false
            },
            "merge_multi_user": {
                "description": "允许合并多人消息",
                "hint": "开启后，合并窗口期间若有其他群成员发送消息，也会被一并收集。",
                "type": "bool",
                "default": false
            },
            "max_user_concurrent_requests": {
                "description": "用户级并发请求上限",
                "hint": "限制单个用户同时进行中的 LLM 请求数。设为 0 表示不限制。",
                "type": "int",
                "minimum": 0,
                "default": 0
            },
            "max_group_concurrent_requests": {
                "description": "群聊级并发请求上限",
                "hint": "限制单个群同时进行中的 LLM 请求数。设为 0 表示不限制。",
                "type": "int",
                "minimum": 0,
                "default": 0
            },
            "group_sender_concurrency": {
                "description": "群聊按用户并发",
                "hint": "开启后，同群内不同用户的 LLM 请求各自独立排队，不再全局串行等待，可同时进行处理。同一用户连续发消息仍然串行。若同时开启了动态合并 + 多人合并，此功能将不会生效。",
                "type": "bool",
                "default": false
            }
        }
    },
    "context_injection": {
        "type": "object",
        "description": "上下文注入",
        "hint": "用于记录并注入轻量对话上下文，为后续读空气与主动唤醒优化提供基础数据。",
        "items": {
            "context_injection_mode": {
                "description": "上下文注入模式",
                "hint": "控制轻量上下文记录与注入策略。",
                "type": "string",
                "options": [
                    "off",
                    "before_active_only",
                    "before_all_wake"
                ],
                "labels": [
                    "不启用",
                    "仅主动唤醒前",
                    "所有唤醒前"
                ],
                "default": "off"
            },
            "context_injection_max_messages": {
                "description": "上下文记录上限",
                "hint": "每个会话最多保留的上下文消息条数。建议 6~50。",
                "type": "int",
                "default": 12
            },
            "context_injection_format": {
                "description": "上下文注入格式",
                "hint": "精简：仅注入时间+发送者+文本（含引用摘要）；详细：注入完整结构字段（含 msg_id、uid、@信息、reply 信息）。",
                "type": "string",
                "options": [
                    "simple",
                    "detailed"
                ],
                "labels": [
                    "精简",
                    "详细"
                ],
                "default": "simple"
            },
            "context_injection_non_text_parse_options": {
                "description": "非文本消息解析选项",
                "hint": "控制上下文记录阶段对非文本消息的处理方式。未勾选时使用占位符。聊天记录仅抽取文本，不做媒体解析。",
                "type": "list",
                "options": [
                    "image",
                    "record",
                    "forward",
                    "url",
                    "file",
                    "json"
                ],
                "labels": [
                    "图片",
                    "语音",
                    "聊天记录",
                    "URL",
                    "文件",
                    "JSON"
                ],
                "default": []
            },
            "context_injection_image_caption_provider_id": {
                "description": "上下文图像转述 Provider ID",
                "type": "string",
                "_special": "select_provider",
                "default": "",
                "hint": "留空时自动选择具备图片能力的 Provider。"
            }
        }
    },
    "parse_switches": {
        "type": "object",
        "description": "解析总开关",
        "hint": "统一控制各类内容解析能力是否启用。",
        "items": {
            "video_parse_enable": {
                "description": "启用视频解析",
                "type": "bool",
                "default": true,
                "hint": "关闭后，不再执行视频与 GIF 的媒体增强解析。"
            },
            "forward_parse_enable": {
                "description": "启用聊天记录解析",
                "type": "bool",
                "default": true,
                "hint": "关闭后，不再解析聊天记录（合并转发消息）内容。"
            },
            "file_parse_enable": {
                "description": "启用文件解析",
                "type": "bool",
                "default": true,
                "hint": "关闭后，不再提取或注入引用消息中的文件信息。"
            },
            "json_parse_enable": {
                "description": "启用 JSON 卡片解析",
                "type": "bool",
                "default": true,
                "hint": "关闭后，不再提取引用消息中的 JSON 卡片关键信息（如分享卡片标题、摘要、链接）。"
            },
            "url_parse_enable": {
                "description": "启用 URL 解析",
                "type": "bool",
                "default": true,
                "hint": "关闭后，不再抓取并注入消息中的 URL 内容摘要。"
            },
            "record_parse_enable": {
                "description": "启用语音解析",
                "type": "bool",
                "default": true,
                "hint": "关闭后，不再进行语音转写（ASR），仅保留占位提示。"
            }
        }
    },
    "video_injection": {
        "type": "object",
        "description": "视频解析",
        "hint": "配置视频抽帧、语音识别和相关模型参数。",
        "items": {
            "video_max_size_mb": {
                "description": "视频大小上限（MB）",
                "hint": "单个视频超过该大小时将跳过解析。默认 50MB。",
                "type": "int",
                "default": 50
            },
            "gif_parse_enable": {
                "description": "启用 GIF 抽帧解析",
                "type": "bool",
                "default": false,
                "hint": "关闭时，GIF 不走插件抽帧流程，保留框架原生图片处理；开启后，GIF 将按类似视频的方式抽帧总结。"
            },
            "video_frame_interval_sec": {
                "description": "抽帧间隔（秒）",
                "hint": "每隔 N 秒取 1 帧。间隔越小描述越细腻，但会消耗更多 Token 和时间。",
                "type": "int",
                "default": 12
            },
            "video_max_frame_count": {
                "description": "抽帧数量上限",
                "type": "int",
                "default": 10,
                "hint": "单个视频最多抽取的帧数。若根据抽帧间隔计算出的帧数超过此值，将自动调整间隔以匹配此上限。"
            },
            "video_sample_count": {
                "description": "视频抽帧数量",
                "type": "int",
                "default": 3,
                "hint": "当无法探测视频时长时，默认抽取该数量的帧。"
            },
            "video_asr_enable": {
                "description": "视频语音识别 (ASR)",
                "type": "bool",
                "default": true,
                "hint": "开启后，将提取视频音频并转写为文本，辅助模型理解视频内容。"
            },
            "asr_provider_id": {
                "description": "ASR 提供商 ID",
                "type": "string",
                "_special": "select_provider_stt",
                "hint": "用于将视频音频或语音内容转写为文本。若留空，则跳过 STT Provider，直接尝试下方配置的 LLM 语音转写提供商。"
            },
            "asr_llm_provider_id": {
                "description": "LLM 语音转写提供商 ID",
                "type": "string",
                "_special": "select_provider",
                "default": "",
                "hint": "当指定的 STT Provider 未配置或转写失败时，使用此 LLM Provider 做语音转写。模型需在提供商配置中勾选 audio 能力；若不支持则直接放弃。"
            },
            "image_provider_id": {
                "description": "图片转述 Provider ID",
                "type": "string",
                "_special": "select_provider",
                "hint": "用于理解视频/GIF 的逐帧画面内容。留空时自动选择当前可用的具备图片能力的 Provider。"
            },
            "video_summary_provider_id": {
                "description": "视频摘要 Provider ID",
                "type": "string",
                "_special": "select_provider",
                "hint": "用于将视频/GIF 的逐帧描述与语音转写结果汇总为最终摘要。留空时使用当前会话正在使用的 Provider。"
            },
            "ffmpeg_path": {
                "description": "FFmpeg 路径",
                "hint": "FFmpeg 可执行文件路径，不填则自动尝试从系统环境变量中寻找。",
                "type": "string",
                "default": ""
            },
            "quote_self_video_block_prob": {
                "description": "引用 Bot 自身视频的请求屏蔽概率",
                "hint": "当引用 Bot 自身发送的视频消息时，按该概率屏蔽请求。",
                "type": "float",
                "slider": {
                    "min": 0,
                    "max": 1,
                    "step": 0.01
                },
                "default": 0
            }
        }
    },
    "forward_parsing": {
        "type": "object",
        "description": "聊天记录解析",
        "hint": "配置聊天记录解析的策略与限制。",
        "items": {
            "nested_parse_depth": {
                "description": "嵌套解析深度",
                "type": "int",
                "default": 5,
                "hint": "限制递归解析层数。"
            },
            "forward_message_max_count": {
                "description": "消息读取上限",
                "type": "int",
                "default": 50,
                "hint": "单次最多读取并解析的聊天记录内部消息条数。"
            },
            "forward_image_max_count": {
                "description": "图片注入上限",
                "type": "int",
                "default": 8,
                "hint": "单次聊天记录解析最多注入的图片数量，超出部分将被忽略。"
            },
            "forward_video_max_count": {
                "description": "最多处理视频数量",
                "type": "int",
                "default": 2,
                "hint": "单次聊天记录解析最多处理的视频条数。设为 0 时关闭聊天记录视频抽帧，仅保留视频占位符。"
